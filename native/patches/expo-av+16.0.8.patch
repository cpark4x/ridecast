diff --git a/node_modules/expo-av/ios/EXAV/EXAVCompat.h b/node_modules/expo-av/ios/EXAV/EXAVCompat.h
new file mode 100644
index 0000000..269ccc3
--- /dev/null
+++ b/node_modules/expo-av/ios/EXAV/EXAVCompat.h
@@ -0,0 +1,22 @@
+// EXAVCompat.h — Compatibility shims for expo-modules-core@55.x
+// EXFatal and EXErrorWithMessage were removed in SDK 55.
+// This header provides inline replacements for expo-av@16.0.8.
+
+#ifndef EXAVCompat_h
+#define EXAVCompat_h
+
+#import <Foundation/Foundation.h>
+
+#ifndef EXErrorWithMessage
+static inline NSError * _Nonnull EXErrorWithMessage(NSString * _Nonnull message) {
+  return [NSError errorWithDomain:@"expo-av" code:0 userInfo:@{NSLocalizedDescriptionKey: message}];
+}
+#endif
+
+#ifndef EXFatal
+static inline void EXFatal(NSError * _Nonnull error) {
+  NSLog(@"[expo-av] Fatal: %@", error.localizedDescription);
+}
+#endif
+
+#endif
