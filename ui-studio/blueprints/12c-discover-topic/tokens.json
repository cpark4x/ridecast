{
  "_meta": {
    "screen": "12c Discover Topic Feed (Science)",
    "app": "Ridecast",
    "design-system": "ui-studio/moodboard/aesthetic-brief.md",
    "note": "Values reconciled against 16-frame design system brief — brief values are ground truth over VLM pixel estimates"
  },

  "colors": {
    "color-background-screen": "#0F0F1A",
    "color-surface-card": "#1A1A2E",
    "color-surface-elevated": "#242438",
    "color-text-primary": "#FFFFFF",
    "color-text-secondary": "#9CA3AF",
    "color-tab-inactive": "#6B7280",
    "color-tab-active": "#FF6B35",
    "color-accent-primary": "#FF6B35",
    "color-accent-science": "#0D9488",
    "color-progress-track": "#242438",
    "border-top-subtle": "rgba(255, 255, 255, 0.06)"
  },

  "typography": {
    "font-family-primary": "Geist",
    "font-family-fallback": "system-ui, -apple-system, sans-serif",

    "font-size-topic-title": "28px",
    "font-size-article-title": "15px",
    "font-size-article-meta": "12px",
    "font-size-mini-player-title": "14px",
    "font-size-mini-player-percent": "12px",
    "font-size-back-nav": "15px",
    "font-size-topic-stats": "13px",
    "font-size-tab-label": "11px",

    "font-weight-regular": 400,
    "font-weight-medium": 500,
    "font-weight-semibold": 600,
    "font-weight-bold": 700,

    "line-height-tight": "1.2",
    "line-height-normal": "1.5"
  },

  "spacing": {
    "spacing-xs": "4px",
    "spacing-sm": "8px",
    "spacing-md": "16px",
    "spacing-lg": "24px",
    "spacing-screen-margin": "20px",
    "spacing-card-padding-v": "12px",
    "spacing-card-padding-h": "12px",
    "spacing-card-gap": "12px",
    "spacing-section-gap": "24px"
  },

  "dimensions": {
    "height-tab-bar": "56px",
    "height-mini-player": "60px",
    "height-back-nav-bar": "44px",
    "height-article-card": "76px",
    "height-progress-bar": "3px",
    "height-accent-underline": "3px",
    "width-accent-underline": "76px",
    "width-thumbnail": "72px",
    "height-thumbnail": "72px",
    "width-thumbnail-mini": "40px",
    "height-thumbnail-mini": "40px",
    "size-add-button": "28px",
    "size-nav-icon": "24px",
    "size-player-icon": "24px"
  },

  "border-radius": {
    "radius-card": "10px",
    "radius-thumbnail": "8px",
    "radius-mini-player": "14px",
    "radius-add-button": "9999px",
    "radius-pill": "9999px",
    "radius-sm": "4px"
  },

  "shadows": {
    "shadow-mini-player": "0 4px 16px rgba(0, 0, 0, 0.3)"
  }
}
